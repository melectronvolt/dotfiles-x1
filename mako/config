# ~/.config/mako/config

font=JetBrainsMono Nerd Font 11
background-color=#1a1a1aee
text-color=#e4e4e4
border-color=#f9e2af
border-size=2
border-radius=10
padding=12,16
margin=8
outer-margin=12
default-timeout=5000
icons=1
max-icon-size=48
width=360
height=120
anchor=top-right
layer=overlay

[urgency=low]
border-color=#3a3a3a
default-timeout=3000

[urgency=normal]
border-color=#f9e2af

[urgency=high]
border-color=#f38ba8
default-timeout=0
