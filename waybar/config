{
    "layer": "top",
    "position": "top",
    "height": 40,
    "spacing": 6,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,
    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "sway/window"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "temperature",
        "cpu",
        "memory",
        "battery",
        "power-profiles-daemon",
        "pulseaudio",
        "network",
        "custom/vpn",
        "bluetooth",
        "custom/power",
        "tray"
    ],
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}"
    },
    "sway/mode": {
        "format": "<span style=\"italic\">´éş {}</span>",
        "tooltip": false
    },
    "sway/window": {
        "format": "{title}",
        "max-length": 60,
        "tooltip": false
    },
    "clock": {
        "interval": 10,
        "format": "´ü│  {:%H:%M    %a %d %b}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "cpu": {
        "interval": 2,
        "format": "´őŤ  {usage}%",
        "tooltip": false
    },
    "memory": {
        "interval": 5,
        "format": "´ł│  {used:0.1f}G"
    },
    "temperature": {
        "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
        "input-filename": "temp1_input",
        "critical-threshold": 85,
        "interval": 3,
        "format": "´őë {temperatureC}┬░C",
        "format-critical": "´ü▒ {temperatureC}┬░C"
    },
    "battery": {
        "interval": 10,
        "states": {
            "warning": 25,
            "critical": 10
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "´âž  {capacity}%",
        "format-plugged": "´çŽ  {capacity}%",
        "format-icons": [
            "´ëä",
            "´ëâ",
            "´ëé",
            "´ëü",
            "´ëÇ"
        ],
        "tooltip-format": "{timeTo}"
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Profile: {profile}\nDriver: {driver}",
        "format-icons": {
            "default": "´âž",
            "performance": "´âž",
            "balanced": "´âž",
            "power-saver": "´üČ"
        }
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "´ÇŽ",
        "format-icons": {
            "default": [
                "´ÇŽ",
                "´Çž",
                "´ÇĘ"
            ]
        },
        "on-click": "pavucontrol",
        "scroll-step": 5
    },
    "bluetooth": {
        "format": "´Őô",
        "format-connected": "´Őô  {num_connections}",
        "format-disabled": "´ü×",
        "format-off": "´ü×",
        "tooltip-format": "Bluetooth on",
        "tooltip-format-connected": "{num_connections} device(s)\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "tooltip-format-disabled": "Bluetooth disabled",
        "tooltip-format-off": "Bluetooth off",
        "on-click": "blueman-manager"
    },
    "network": {
        "format-wifi": "{icon}  {signalStrength}%",
        "format-ethernet": "´âĘ",
        "format-disconnected": "´ü▒",
        "format-icons": [
            "´Çĺ",
            "´Çĺ",
            "´Çĺ",
            "´Çĺ",
            "´Çĺ"
        ],
        "tooltip-format-wifi": "{essid}\n{ifname}  ┬Ě  {ipaddr}",
        "tooltip-format-ethernet": "{ifname}\n{ipaddr}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "nm-connection-editor"
    },
    "custom/vpn": {
        "exec": "/home/remi/.local/bin/vpn-status",
        "interval": 3,
        "return-type": "json",
        "on-click": "/home/remi/.local/bin/vpn-toggle",
        "tooltip": true
    },
    "custom/power": {
        "format": "ÔĆ╗",
        "tooltip": "Power menu",
        "on-click": "/home/remi/.local/bin/power-menu"
    },
    "tray": {
        "icon-size": 16,
        "spacing": 8
    }
}
