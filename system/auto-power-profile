#!/bin/bash
# Bascule tuned profile ET swayidle config selon l'état de l'adaptateur secteur.
set -euo pipefail

# Detection AC online
online=0
for f in /sys/class/power_supply/*/type; do
    if [ "$(cat "$f")" = "Mains" ]; then
        online=$(cat "$(dirname "$f")/online" 2>/dev/null || echo 0)
        break
    fi
done

# ---- Partie 1 : tuned profile ----
if [ "$online" = "1" ]; then
    target="throughput-performance"
else
    target="powersave"
fi

current=$(tuned-adm active 2>/dev/null | awk -F': ' '/active profile/ {print $2}')
if [ "$current" != "$target" ]; then
    tuned-adm profile "$target"
    logger -t auto-power-profile "AC=$online, switched to $target (was $current)"
fi

# ---- Partie 2 : swayidle config ----
# Lancer la bascule en tant qu'user remi dans sa session Sway
if pgrep -u remi sway >/dev/null; then
    sudo -u remi /home/remi/.local/bin/swayidle-switch || true
fi
