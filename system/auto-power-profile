#!/bin/bash
# Bascule tuned profile selon l'état de l'adaptateur secteur.
set -euo pipefail

# Lit l'état du premier "Mains" (AC adapter) trouvé dans /sys.
# Gère les variantes de nommage selon le hardware (AC, ACAD, ADP0, etc.).
online=0
for f in /sys/class/power_supply/*/type; do
    if [ "$(cat "$f")" = "Mains" ]; then
        online=$(cat "$(dirname "$f")/online" 2>/dev/null || echo 0)
        break
    fi
done

# Profils cibles (en noms tuned, traduits par tuned-ppd vers PPD)
if [ "$online" = "1" ]; then
    target="throughput-performance"   # -> "performance" côté PPD
else
    target="powersave"                # -> "power-saver" côté PPD
fi

current=$(tuned-adm active 2>/dev/null | awk -F': ' '/active profile/ {print $2}')
if [ "$current" != "$target" ]; then
    tuned-adm profile "$target"
    logger -t auto-power-profile "AC=$online, switched to $target (was $current)"
fi
