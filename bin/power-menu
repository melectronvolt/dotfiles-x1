#!/bin/bash
options="  Lock
  Suspend
󰗽  Logout
  Reboot
  Shutdown"

choice=$(echo -e "$options" | wofi --dmenu --prompt "Power" --width 300 --height 280 --cache-file /dev/null)

case "$choice" in
    *Lock*)      ~/.local/bin/sway-lock ;;
    *Suspend*)   ~/.local/bin/sway-lock & systemctl suspend ;;
    *Logout*)    swaymsg exit ;;
    *Reboot*)    systemctl reboot ;;
    *Shutdown*)  systemctl poweroff ;;
esac
