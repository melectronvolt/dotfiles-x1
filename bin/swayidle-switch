#!/bin/bash
set -euo pipefail

online=0
for f in /sys/class/power_supply/*/type; do
    if [ "$(cat "$f")" = "Mains" ]; then
        online=$(cat "$(dirname "$f")/online" 2>/dev/null || echo 0)
        break
    fi
done

if [ "$online" = "1" ]; then
    config="$HOME/.config/swayidle/ac.conf"
    state="AC"
else
    config="$HOME/.config/swayidle/battery.conf"
    state="BAT"
fi

pkill -x swayidle 2>/dev/null || true
sleep 0.2

if [ -z "${WAYLAND_DISPLAY:-}" ]; then
    WAYLAND_DISPLAY=$(basename $(ls -t /run/user/$(id -u)/wayland-* 2>/dev/null | grep -v '\.lock$' | head -1) 2>/dev/null)
    export WAYLAND_DISPLAY
    export XDG_RUNTIME_DIR=/run/user/$(id -u)
fi

if [ -z "${SWAYSOCK:-}" ]; then
    SWAYSOCK=$(ls -t /run/user/$(id -u)/sway-ipc.*.sock 2>/dev/null | head -1)
    export SWAYSOCK
fi

if [ -z "$WAYLAND_DISPLAY" ] || [ -z "$SWAYSOCK" ]; then
    logger -t swayidle-switch "Error: no Sway session found"
    exit 1
fi

swayidle -w -C "$config" &
disown
logger -t swayidle-switch "Switched to $state config ($config)"
