#!/bin/bash
VPN_NAME="Fedora-CH-247"

if ! nmcli -t -f NAME connection show 2>/dev/null | grep -q "^${VPN_NAME}$"; then
    notify-send "VPN" "Profile $VPN_NAME not found" -u critical
    exit 1
fi

if nmcli -t -f NAME connection show --active 2>/dev/null | grep -q "^${VPN_NAME}$"; then
    nmcli connection down "$VPN_NAME" && notify-send "VPN" "Disconnected from $VPN_NAME"
else
    nmcli connection up "$VPN_NAME" && notify-send "VPN" "Connected to $VPN_NAME" || \
        notify-send "VPN" "Failed to connect to $VPN_NAME" -u critical
fi
